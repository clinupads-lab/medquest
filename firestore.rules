rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Progresso do usuário: cada um lê/escreve apenas o próprio documento.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Banco de questões: leitura para qualquer usuário autenticado.
    // Escrita bloqueada pelo cliente — o seed/edição é feito via script
    // com credencial de administrador (firebase-admin), que ignora estas regras.
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
