rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Progresso do usuário: cada um só lê/escreve o próprio documento.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Banco de questões: leitura pública (não são sensíveis e já vão no app),
    // para carregar mesmo antes do login. Escrita só via script admin (seed).
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Tudo o mais é negado por padrão.
  }
}
