rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Progresso do usuário: cada um só lê/escreve o próprio documento.
    // MAS os campos de plano/assinatura são intocáveis pelo cliente — só o
    // webhook do Mercado Pago (Admin SDK, que ignora estas regras) escreve
    // neles. Sem isso, qualquer um viraria premium pelo console do navegador.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.get('plan', 'free') == 'free'
                    && !request.resource.data.keys().hasAny(['planTier', 'subscription']);
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['plan', 'planTier', 'subscription']);
    }

    // Assinaturas (auditoria do checkout): o dono pode ler a própria;
    // escrita só pelo backend (Admin SDK).
    match /subscriptions/{subId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Banco de questões: leitura pública; escrita só via script admin (seed).
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Diretório público de códigos de amigo (code -> uid/nome).
    // Só é possível reivindicar um código que aponte para você mesmo.
    match /userCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }

    // Amizades (par de uids). Leitura para autenticados (necessária para
    // checagem de convites); escrita só por quem faz parte do par.
    match /friendships/{pairId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.requesterUid == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    // Batalhas: só os participantes leem/escrevem.
    match /battles/{battleId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.challengerUid == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // Salas em grupo (Kahoot): leitura para autenticados (necessária para entrar
    // pelo código); criação pelo host; atualização por qualquer participante logado.
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow update: if request.auth != null;
    }

    // Placar de vitórias: leitura para autenticados (ranking entre amigos);
    // cada um só escreve o próprio total.
    match /battleStats/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
