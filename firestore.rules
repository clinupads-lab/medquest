rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Progresso do usuário: cada um só lê/escreve o próprio documento.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Banco de questões: leitura pública; escrita só via script admin (seed).
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Diretório público de códigos de amigo (code -> uid/nome).
    // Só é possível reivindicar um código que aponte para você mesmo.
    match /userCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }

    // Amizades (par de uids). Leitura para autenticados (necessária para
    // checagem de convites); escrita só por quem faz parte do par.
    match /friendships/{pairId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.requesterUid == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    // Batalhas: só os participantes leem/escrevem.
    match /battles/{battleId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.challengerUid == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // Salas em grupo (Kahoot): leitura para autenticados (necessária para entrar
    // pelo código); criação pelo host; atualização por qualquer participante logado.
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow update: if request.auth != null;
    }
  }
}
